# RAG Backend Test Configuration Template
# Copy this file to test-config.env and update with your environment details

# ============================================================================
# REQUIRED: RAG Backend URL
# ============================================================================
# The external route URL for your RAG backend service
# Example: https://rag-backend-opensearch-llm-on-techzone.apps.p1234.cecc.ihost.com
RAG_BACKEND_URL="https://rag-backend-opensearch-<namespace>.<domain>"

# ============================================================================
# OPTIONAL: Test Configuration
# ============================================================================

# Skip SSL certificate verification (use for self-signed certs)
# Set to "true" to use curl -k flag
SKIP_SSL_VERIFY="true"

# Test timeout in seconds
TEST_TIMEOUT="60"

# Verbose output (true/false)
VERBOSE="false"

# ============================================================================
# OPTIONAL: Test Data Configuration
# ============================================================================

# Collection name for tests
TEST_COLLECTION="test_sales_manuals"

# PDF files to test (comma-separated, no spaces)
TEST_PDFS="IBM_Power_S1012,IBM_Power_S1014"

# Number of search results to retrieve
SEARCH_K="3"

# Search mode: dense, sparse, or hybrid
SEARCH_MODE="hybrid"

# ============================================================================
# OPTIONAL: LLM Configuration
# ============================================================================

# LLM temperature (0.0 to 1.0)
LLM_TEMPERATURE="0.1"

# LLM max tokens to generate
LLM_N_PREDICT="100"

# ============================================================================
# OPTIONAL: Test Questions
# ============================================================================

# Questions for search and RAG testing (one per line)
TEST_QUESTIONS=(
  "How many processors does the IBM Power S1012 support?"
  "What are the memory specifications?"
  "What is the maximum storage capacity?"
)

# ============================================================================
# OPTIONAL: Expected Results (for validation)
# ============================================================================

# Expected keywords in search results (for quality checks)
EXPECTED_KEYWORDS="processor,memory,storage,IBM,Power"

# ============================================================================
# OPTIONAL: Persistence Test Configuration
# ============================================================================

# Namespace for OCP commands (if running persistence tests)
OCP_NAMESPACE="llm-on-techzone"

# Pod label selector for RAG backend
RAG_BACKEND_LABEL="app=rag-backend-opensearch"

# Pod label selector for OpenSearch
OPENSEARCH_LABEL="app=opensearch"

# ============================================================================
# NOTES
# ============================================================================
# 1. Only RAG_BACKEND_URL is required
# 2. All other settings have sensible defaults
# 3. For Windows PowerShell, use forward slashes in URLs
# 4. Test scripts will source this file if it exists